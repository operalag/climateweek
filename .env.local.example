# ============================================================================
# Climate Week Zurich — local env
# Copy to .env.local and fill in. All secret keys are inherited from the
# shell environment by default; set here only if you want to override.
# ============================================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# --- LLMs ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
PERPLEXITY_API_KEY=

# --- Search / Crawl ---
FIRECRAWL_API_KEY=
SERPAPI_API_KEY=
GOOGLE_PLACES_API=

# --- News ---
GUARDIAN_API_KEY=
NEWSAPI_API_KEY=
MEDIASTACK_API_KEY=

# --- Contact / B2B ---
APPOLLO_API_KEY=
RAPIAPI_API_KEY=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
CWZ_YEAR=2026
CWZ_START_DATE=2026-05-04
CWZ_END_DATE=2026-05-09
